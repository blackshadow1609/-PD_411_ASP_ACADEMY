@page "/students/create"
@using Microsoft.EntityFrameworkCore
@using Academy2.Models
@using System  // ДОБАВИТЬ
@inject IDbContextFactory<Academy2.Data.Academy2Context> DbFactory
@inject NavigationManager NavigationManager
@rendermode InteractiveServer 

<PageTitle>Create</PageTitle>

<h1>Create</h1>

<h2>Student</h2>
<hr />
<div class="row">
    <div class="col-md-4">
        <EditForm method="post" Model="Student" OnValidSubmit="AddStudent" FormName="create" Enhance>
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert" />
            <div class="human-container">
                <div class="col-md-4">
                    <div class="mb-3">
                        <span class="text-danger">*</span>
                        <label for="last_name" class="form-label">last_name:</label>
                        <InputText id="last_name" @bind-Value="Student.last_name" class="form-control" aria-required="true" />
                        <ValidationMessage For="() => Student.last_name" class="text-danger" />
                    </div>
                    <div class="mb-3">
                        <span class="text-danger">*</span>
                        <label for="first_name" class="form-label">first_name:</label>
                        <InputText id="first_name" @bind-Value="Student.first_name" class="form-control" aria-required="true" />
                        <ValidationMessage For="() => Student.first_name" class="text-danger" />
                    </div>
                    <div class="mb-3">
                        <label for="middle_name" class="form-label">middle_name:</label>
                        <InputText id="middle_name" @bind-Value="Student.middle_name" class="form-control" />
                        <ValidationMessage For="() => Student.middle_name" class="text-danger" />
                    </div>
                    <div class="mb-3">
                        <span class="text-danger">*</span>
                        <label for="birth_date" class="form-label">birth_date:</label>
                        <InputDate id="birth_date" @bind-Value="Student.birth_date" class="form-control" aria-required="true" />
                        <ValidationMessage For="() => Student.birth_date" class="text-danger" />
                    </div>
                    <div class="mb-3">
                        <label for="email" class="form-label">email:</label>
                        <InputText id="email" @bind-Value="Student.email" class="form-control" />
                        <ValidationMessage For="() => Student.email" class="text-danger" />
                    </div>
                    <div class="mb-3">
                        <label for="phone" class="form-label">phone:</label>
                        <InputText id="phone" @bind-Value="Student.phone" class="form-control" />
                        <ValidationMessage For="() => Student.phone" class="text-danger" />
                    </div>
                    <div class="mb-3">
                        <label for="group" class="form-label">group:</label>
                        <InputSelect @bind-Value="Student.group" class="form-control">
                            @{
                                using var context = DbFactory.CreateDbContext();
                                foreach (Group group in context.Groups)
                                {
                                    <option value="@group.group_id">@group.group_name</option>
                                }
                            }
                        </InputSelect>
                        <ValidationMessage For="() => Student.group" class="text-danger" />
                    </div>
                </div>
                <div class="photo-container">
                    <Photo url="@url" />
                    <InputFile OnChange="LoadPhoto" />
                </div>
            </div>
            <button type="submit" class="btn btn-primary">Create</button>
        </EditForm>
    </div>
</div>

<div>
    <a href="/students">Back to List</a>
</div>

<style>
    .human-container {
        width: 100%;
        display: flex;
        justify-content: space-between;
    }
    
    .photo-container {
        width: 40%;
    }
</style>

@code {
    [SupplyParameterFromForm]
    private Student Student { get; set; } = default!;
    
    string? url { get; set; }

    protected override void OnInitialized() => Student ??= new();
    
    async Task LoadPhoto(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 5_000_000);
            var bytes = new byte[stream.Length];
            await stream.ReadAsync(bytes);
            url = $"data:image/jpeg;base64,{Convert.ToBase64String(bytes)}";
            Student.photo = bytes;
        }
    }

    private async Task AddStudent()
    {
        using var context = DbFactory.CreateDbContext();
        context.Students.Add(Student);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/students");
    }
}