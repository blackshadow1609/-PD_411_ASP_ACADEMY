@page "/teachers/details"
@using Microsoft.EntityFrameworkCore
@using Academy2.Models
@using System
@inject IDbContextFactory<Academy2.Data.Academy2Context> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Details</PageTitle>

<h1>Details</h1>

<div>
    <h2>Teacher</h2>
    <hr />
    @if (teacher is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <div class="custom-details-container custom-animated">
            <div class="custom-details-info">
                <div class="custom-detail-row">
                    <span class="custom-detail-label">work_since:</span>
                    <span class="custom-detail-value">@teacher.work_since</span>
                </div>
                <div class="custom-detail-row">
                    <span class="custom-detail-label">rate:</span>
                    <span class="custom-detail-value">@teacher.rate</span>
                </div>
                <div class="custom-detail-row">
                    <span class="custom-detail-label">teacher_id:</span>
                    <span class="custom-detail-value">@teacher.teacher_id</span>
                </div>
                <div class="custom-detail-row">
                    <span class="custom-detail-label">last_name:</span>
                    <span class="custom-detail-value">@teacher.last_name</span>
                </div>
                <div class="custom-detail-row">
                    <span class="custom-detail-label">first_name:</span>
                    <span class="custom-detail-value">@teacher.first_name</span>
                </div>
                <div class="custom-detail-row">
                    <span class="custom-detail-label">middle_name:</span>
                    <span class="custom-detail-value">@teacher.middle_name</span>
                </div>
                <div class="custom-detail-row">
                    <span class="custom-detail-label">birth_date:</span>
                    <span class="custom-detail-value">@teacher.birth_date</span>
                </div>
                <div class="custom-detail-row">
                    <span class="custom-detail-label">email:</span>
                    <span class="custom-detail-value">@teacher.email</span>
                </div>
                <div class="custom-detail-row">
                    <span class="custom-detail-label">phone:</span>
                    <span class="custom-detail-value">@teacher.phone</span>
                </div>
            </div>
            <div class="custom-details-photo">
                <h3>Photo</h3>
                @if (teacher.photo != null && teacher.photo.Length > 0)
                {
                    <img src="@($"data:image/jpeg;base64,{Convert.ToBase64String(teacher.photo)}")" class="custom-photo-preview" />
                }
                else
                {
                    <div class="custom-photo-placeholder">No photo</div>
                }
            </div>
        </div>
        <div class="mt-3">
            <a href="@($"/teachers/edit?teacher_id={teacher.teacher_id}")">Edit</a> |
            <a href="/teachers">Back to List</a>
        </div>
    }
</div>

@code {
    private Teacher? teacher;

    [SupplyParameterFromQuery]
    private int teacher_id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        teacher = await context.Teachers.FirstOrDefaultAsync(m => m.teacher_id == teacher_id);

        if (teacher is null)
        {
            NavigationManager.NotFound();
        }
    }
}