@page "/teachers/edit"
@using Microsoft.EntityFrameworkCore
@using Academy2.Models
@using System
@inject IDbContextFactory<Academy2.Data.Academy2Context> DbFactory
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Edit</PageTitle>

<h1>Edit</h1>

<h2>Teacher</h2>
<hr />
@if (Teacher is null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row">
        <div>
            <EditForm method="post" Model="Teacher" OnValidSubmit="UpdateTeacher" FormName="edit" Enhance class="custom-edit-form">
                <DataAnnotationsValidator />
                <ValidationSummary role="alert" />
                <div class="custom-human-container">
                    <div class="col-md-4">
                        <input type="hidden" name="Teacher.teacher_id" value="@Teacher.teacher_id" />

                        <div class="mb-3">
                            <span class="text-danger">*</span>
                            <label for="last_name" class="form-label">last_name:</label>
                            <InputText id="last_name" @bind-Value="Teacher.last_name" class="form-control" aria-required="true" />
                            <ValidationMessage For="() => Teacher.last_name" class="text-danger" />
                        </div>
                        <div class="mb-3">
                            <span class="text-danger">*</span>
                            <label for="first_name" class="form-label">first_name:</label>
                            <InputText id="first_name" @bind-Value="Teacher.first_name" class="form-control" aria-required="true" />
                            <ValidationMessage For="() => Teacher.first_name" class="text-danger" />
                        </div>
                        <div class="mb-3">
                            <label for="middle_name" class="form-label">middle_name:</label>
                            <InputText id="middle_name" @bind-Value="Teacher.middle_name" class="form-control" />
                            <ValidationMessage For="() => Teacher.middle_name" class="text-danger" />
                        </div>
                        <div class="mb-3">
                            <span class="text-danger">*</span>
                            <label for="birth_date" class="form-label">birth_date:</label>
                            <InputDate id="birth_date" @bind-Value="Teacher.birth_date" class="form-control" aria-required="true" />
                            <ValidationMessage For="() => Teacher.birth_date" class="text-danger" />
                        </div>
                        <div class="mb-3">
                            <label for="email" class="form-label">email:</label>
                            <InputText id="email" @bind-Value="Teacher.email" class="form-control" />
                            <ValidationMessage For="() => Teacher.email" class="text-danger" />
                        </div>
                        <div class="mb-3">
                            <label for="phone" class="form-label">phone:</label>
                            <InputText id="phone" @bind-Value="Teacher.phone" class="form-control" />
                            <ValidationMessage For="() => Teacher.phone" class="text-danger" />
                        </div>
                        <div class="mb-3">
                            <label for="work_since" class="form-label">work_since:</label>
                            <InputDate id="work_since" @bind-Value="Teacher.work_since" class="form-control" />
                            <ValidationMessage For="() => Teacher.work_since" class="text-danger" />
                        </div>
                        <div class="mb-3">
                            <label for="rate" class="form-label">rate:</label>
                            <InputNumber id="rate" @bind-Value="Teacher.rate" class="form-control" />
                            <ValidationMessage For="() => Teacher.rate" class="text-danger" />
                        </div>
                    </div>
                    <div class="custom-photo-container">
                        <Photo url="@url" />
                        <InputFile OnChange="LoadPhoto" />
                    </div>
                    <div class="mb-3">
                        <h5>Выберите дисциплину:</h5>
                        
                        <InputSelect @bind-Value="SelectedDisciplineId" class="form-control">
                            <option value="">-- Выберите дисциплину --</option>
                            @foreach (Discipline d in Disciplines)
                            {
                                <option value="@d.discipline_id">@d.discipline_name</option>
                            }
                        </InputSelect>
                        
                        <button type="button" class="btn btn-secondary mt-2" @onclick="AddDiscipline" disabled="@(SelectedDisciplineId == 0)">
                            Добавить дисциплину
                        </button>
                        
                        <hr />
                        
                        <h5>Новые дисциплины:</h5>
                        @if (NewDisciplines.Any())
                        {
                            <ul>
                                @foreach (var tdr in NewDisciplines)
                                {
                                    <li>
                                        @tdr.Discipline?.discipline_name
                                        <button type="button" class="btn btn-sm btn-danger ms-2" @onclick="() => RemoveNewDiscipline(tdr)">Удалить</button>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p>Нет добавленных дисциплин</p>
                        }
                        
                        <hr />
                        
                        <h5>Существующие дисциплины:</h5>
                        @if (OriginalDisciplines.Any())
                        {
                            <ul>
                                @foreach (var tdr in OriginalDisciplines)
                                {
                                    <li>
                                        @tdr.Discipline?.discipline_name
                                        <button type="button" class="btn btn-sm btn-danger ms-2" @onclick="() => MarkForDeletion(tdr)">Удалить</button>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p>Нет привязанных дисциплин</p>
                        }
                        
                        @if (DisciplinesToDelete.Any())
                        {
                            <hr />
                            <h5>Будут удалены:</h5>
                            <ul class="text-danger">
                                @foreach (var tdr in DisciplinesToDelete)
                                {
                                    <li>@tdr.Discipline?.discipline_name</li>
                                }
                            </ul>
                        }
                    </div>
                </div>
                <button type="submit" class="btn btn-primary">Save</button>
            </EditForm>
        </div>
    </div>
}

<div>
    <a href="/teachers">Back to List</a>
</div>

@code {
    [SupplyParameterFromQuery]
    private int teacher_id { get; set; }

    [SupplyParameterFromForm]
    private Teacher? Teacher { get; set; }

    private ICollection<Discipline>? Disciplines { get; set; }
    private List<TeacherDisciplineRelation> OriginalDisciplines { get; set; } = new();
    private List<TeacherDisciplineRelation> NewDisciplines { get; set; } = new();
    private List<TeacherDisciplineRelation> DisciplinesToDelete { get; set; } = new();
    
    private int SelectedDisciplineId { get; set; }
    private string? url { get; set; }

    private async Task LoadPhoto(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 5_000_000);
            var bytes = new byte[stream.Length];
            await stream.ReadAsync(bytes);
            url = $"data:image/jpeg;base64,{Convert.ToBase64String(bytes)}";
            Teacher!.photo = bytes;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        
        Teacher ??= await context.Teachers
            .FirstOrDefaultAsync(m => m.teacher_id == teacher_id);

        if (Teacher is null)
        {
            NavigationManager.NotFound();
            return;
        }

        Disciplines = await context.Disciplines.ToListAsync();
       
        OriginalDisciplines = await context.TeachersDisciplinesRelation
            .Include(tdr => tdr.Discipline)
            .Where(tdr => tdr.teacher == teacher_id)
            .ToListAsync();

        if (Teacher.photo != null && Teacher.photo.Length > 0)
        {
            url = $"data:image/jpeg;base64,{Convert.ToBase64String(Teacher.photo)}";
        }
    }

    private void AddDiscipline()
    {
        if (SelectedDisciplineId == 0) return;
        
        if (NewDisciplines.Any(d => d.discipline == SelectedDisciplineId))
        {
            return;
        }
        
        if (OriginalDisciplines.Any(d => d.discipline == SelectedDisciplineId))
        {
            return;
        }
        
        var discipline = Disciplines?.FirstOrDefault(d => d.discipline_id == SelectedDisciplineId);
        if (discipline != null)
        {
            var newRelation = new TeacherDisciplineRelation
            {
                teacher = teacher_id,
                discipline = SelectedDisciplineId,
                Teacher = Teacher,
                Discipline = discipline
            };
            
            NewDisciplines.Add(newRelation);
            SelectedDisciplineId = 0; 
        }
    }
    
    private void RemoveNewDiscipline(TeacherDisciplineRelation tdr)
    {
        NewDisciplines.Remove(tdr);
    }
    
    private void MarkForDeletion(TeacherDisciplineRelation tdr)
    {
        if (DisciplinesToDelete.Contains(tdr))
        {
            DisciplinesToDelete.Remove(tdr);
        }
        else
        {
            DisciplinesToDelete.Add(tdr);
        }
    }

    private async Task UpdateTeacher()
    {
        using var context = DbFactory.CreateDbContext();
       
        context.Attach(Teacher!).State = EntityState.Modified;

        foreach (var tdr in DisciplinesToDelete)
        {
            var relationToDelete = await context.TeachersDisciplinesRelation
                .FirstOrDefaultAsync(r => r.teacher == tdr.teacher && r.discipline == tdr.discipline);
            
            if (relationToDelete != null)
            {
                context.TeachersDisciplinesRelation.Remove(relationToDelete);
            }
        }
        
        foreach (var newRelation in NewDisciplines)
        {
            var relation = new TeacherDisciplineRelation
            {
                teacher = teacher_id,
                discipline = newRelation.discipline
            };
            context.TeachersDisciplinesRelation.Add(relation);
        }

        try
        {
            await context.SaveChangesAsync();
        }
        catch (DbUpdateConcurrencyException)
        {
            if (!await TeacherExists(Teacher!.teacher_id))
            {
                NavigationManager.NotFound();
            }
            else
            {
                throw;
            }
        }

        NavigationManager.NavigateTo("/teachers");
    }

    private async Task<bool> TeacherExists(int teacherId)
    {
        using var context = DbFactory.CreateDbContext();
        return await context.Teachers.AnyAsync(e => e.teacher_id == teacherId);
    }
}